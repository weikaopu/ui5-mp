.ui5-process-flow {
  display: flex;
  align-items: flex-start;
  flex-wrap: nowrap;
}

.ui5-process-flow--horizontal {
  flex-direction: row;
}

.ui5-process-flow--vertical {
  flex-direction: column;
}

.ui5-process-flow__item {
  display: flex;
  flex-direction: column;
  min-width: 180px;
  margin-right: 24px;
  cursor: pointer;
}

.ui5-process-flow--vertical .ui5-process-flow__item {
  margin-right: 0;
  margin-bottom: 20px;
}

.ui5-process-flow__marker-row {
  display: flex;
  align-items: center;
}

.ui5-process-flow__marker {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 2px solid var(--sap-primary-color, #0854a0);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--sap-primary-color, #0854a0);
  font-size: 14px;
  background: #fff;
  flex-shrink: 0;
}

.ui5-process-flow__marker.completed {
  border-color: transparent;
  background: var(--sap-positive-color, #107e3e);
  color: #fff;
}

.ui5-process-flow__marker.active {
  box-shadow: 0 0 0 4px rgba(8, 84, 160, 0.12);
}

.ui5-process-flow__connector {
  flex: 1;
  height: 2px;
  background: #d9dae0;
  margin-left: 12px;
}

.ui5-process-flow__connector.completed {
  background: var(--sap-positive-color, #107e3e);
}

.ui5-process-flow__content {
  margin-top: 14px;
}

.ui5-process-flow__title {
  font-size: 14px;
  font-weight: 700;
  color: var(--sap-text-color, #22313f);
}

.ui5-process-flow__subtitle {
  margin-top: 6px;
  font-size: 12px;
  color: var(--sap-text-subtle-color, #6f7d8c);
}

.ui5-process-flow__description {
  margin-top: 10px;
  font-size: 12px;
  line-height: 1.4;
  color: var(--sap-text-color, #22313f);
}

.ui5-process-flow__badge-row {
  margin-top: 10px;
}

.ui5-process-flow__item.active .ui5-process-flow__title {
  color: var(--sap-primary-color, #0854a0);
}