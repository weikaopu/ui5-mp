/**
 * ui5-range-slider.wxss
 * 基于 SAP Fiori Horizon 设计规范
 */

/* 1. 基础容器 */
.ui5-slider-container {
  padding: 16px 4px;
  width: 100%;
  box-sizing: border-box;
}

.ui5-slider-wrapper {
  display: flex;
  align-items: center;
  gap: 12px;
}

/* 2. 轨道区域 */
.ui5-slider-inner {
  position: relative;
  flex: 1;
  height: 44px;
  /* 触控热区 */
  display: flex;
  align-items: center;
  touch-action: none;
  /* 防止页面滚动干扰拖拽 */
}

/* 轨道基底 */
.ui5-slider-rail {
  position: absolute;
  width: 100%;
  height: 4px;
  background-color: #d8d8d8;
  border-radius: 2px;
}

/* 3. 动态进度条 (关键：Range 模式下 left 和 width 都是变量) */
.ui5-slider-progress {
  position: absolute;
  height: 4px;
  background-color: var(--sap-primary-color);
  border-radius: 2px;
  z-index: 1;
}

/* 4. 刻度点 */
.ui5-slider-tickmarks {
  position: absolute;
  width: 100%;
  height: 4px;
  z-index: 1;
}

.ui5-slider-tick {
  position: absolute;
  top: 50%;
  width: 2px;
  height: 2px;
  background-color: #a9adb2;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

/* 处于选中范围内的刻度点 */
.ui5-slider-tick-active {
  background-color: rgba(255, 255, 255, 0.6);
}

/* 5. 滑块 Handle */
.ui5-slider-handle {
  position: absolute;
  width: 22px;
  height: 22px;
  background-color: var(--sap-content-color);
  border: 1px solid var(--sap-field-border-color);
  border-radius: 50%;
  transform: translate(-50%, 0);
  box-shadow: var(--sap-shadow-level-1);
  z-index: 2;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: transform 0.1s ease-out, box-shadow 0.2s;
}

.ui5-slider-handle-dot {
  width: 4px;
  height: 4px;
  background-color: var(--sap-primary-color);
  border-radius: 50%;
}

/* 激活状态：扩大阴影和缩放 */
.ui5-slider-handle-active {
  z-index: 3;
  /* 确保拖拽中的滑块在最上方 */
  box-shadow: 0 0 0 6px rgba(8, 84, 160, 0.15);
  border-color: var(--sap-primary-color);
  transform: translate(-50%, 0) scale(1.1);
}

/* 6. Tooltip 数值提示 */
.ui5-slider-tooltip {
  position: absolute;
  top: -38px;
  background-color: var(--sap-shell-color);
  color: var(--sap-text-inverted-color);
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: normal;
  pointer-events: none;
  white-space: nowrap;
}

/* 7. 标签文本 */
.ui5-slider-label {
  font-size: var(--sap-font-size-small);
  color: var(--sap-text-secondary-color);
  min-width: 24px;
  text-align: center;
}

/* 8. 禁用状态 */
.ui5-slider-disabled {
  opacity: 0.5;
  pointer-events: none;
}

.ui5-slider-disabled .ui5-slider-progress {
  background-color: var(--sap-neutral-color);
}

.ui5-slider-disabled .ui5-slider-handle {
  border-color: var(--sap-neutral-color);
}

.ui5-slider-disabled .ui5-slider-handle-dot {
  background-color: var(--sap-neutral-color);
}