:host {
  display: block;
}

.ui5-radio-button-root {
  display: flex;
  width: 100%;
  /* 文本换行时，图标与第一行对齐更符合 Fiori 规范 */
  align-items: flex-start;
  padding: var(--sap-spacing-tiny, 8rpx) 0;
  cursor: pointer;
  user-select: none;
  outline: none;
}

/* A11y: Focus state to align with SAP Fiori focus ring */
.ui5-radio-button-root:active .ui5-radio-button-inner {
  outline: 2rpx solid var(--sap-content-focus-color, #0854a0);
  outline-offset: 4rpx;
}

.ui5-radio-button-inner {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  border: 2rpx solid var(--sap-field-border-color, #89919a);
  border-radius: 50%;
  background-color: var(--sap-content-color, #ffffff);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.1s ease-in;
  margin-right: var(--sap-spacing-small, 16rpx);
  margin-top: 4rpx;
  /* 微调图标位置，使其与第一行文字中心对齐 */
}

.ui5-radio-button-checked {
  border-color: var(--sap-selected-color, #0854a0);
  border-width: 2rpx;
}

.ui5-radio-button-icon {
  display: flex;
  color: var(--sap-selected-color, #0854a0);
}

.ui5-radio-button-label {
  flex: 1;
  min-width: 0;
}

.ui5-radio-button-label-inner {
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  overflow: hidden;
}

/* Value States */
.ui5-radio-button-state-Error .ui5-radio-button-inner {
  border-color: var(--sap-error-color, #bb0000);
  border-width: 4rpx;
}

.ui5-radio-button-state-Warning .ui5-radio-button-inner {
  border-color: var(--sap-warning-color, #e9730c);
  border-width: 4rpx;
}

.ui5-radio-button-state-Success .ui5-radio-button-inner {
  border-color: var(--sap-success-color, #107e3e);
  border-width: 4rpx;
}

.ui5-radio-button-state-Information .ui5-radio-button-inner {
  border-color: var(--sap-information-color, #0a6ed1);
  border-width: 4rpx;
}

/* Disabled & Readonly */
.ui5-radio-button-disabled {
  opacity: 0.4;
  pointer-events: none;
}

.ui5-radio-button-readonly .ui5-radio-button-inner {
  background-color: var(--sap-background-color, #f7f7f7);
}

.ui5-radio-button-readonly .ui5-radio-button-checked {
  border-color: var(--sap-field-border-color, #89919a);
}
