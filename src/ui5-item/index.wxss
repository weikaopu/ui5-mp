.ui5-li {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background: var(--sap-content-color);
  border-bottom: 1px solid var(--sap-border-color);
  min-height: 44px;
}

/* Fiori 的细节要求，最后一个 item 移除分割线 */
.ui5-li:last-child {
  border-bottom: none;
}

.ui5-li__icon-vip {
  margin-right: var(--sap-spacing-medium);
  display: flex;
  align-items: center;
  justify-content: center;
  /* 允许内部 Avatar 撑开，或者设置最小宽度 */
  min-width: 24px;
}

/* 针对没有 Icon 时的间距优化 */
.ui5-li__icon-vip:empty {
  display: none;
}

/* 基础布局调整：确保 content 区域能正确计算剩余空间 */
.ui5-li__content {
  /** .ui5-li__content 设置了 flex: 1 和 min-width: 0，保证即使标题和描述再长，右侧的 status 文字和 arrow-right 图标也不会被挤出屏幕。 */
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  /* 关键：必须设置 min-width 为 0，否则内部长文本会撑开父容器导致溢出屏幕 */
  min-width: 0;
}

/* 标题优化：固定单行截断 */
.ui5-li__title {
  font-size: 16px;
  color: var(--sap-text-color);
  line-height: 1.4;
  /* 单行截断标准写法 */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 描述优化：支持多行 */
.ui5-li__description {
  font-size: 12px;
  color: var(--sap-text-secondary-color);
  margin-top: 2px;

  /* 默认开启多行截断（此处以 2 行为例） */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  /* 允许显示的最大行数 */
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  /* 确保长英文单词也能折行 */
  word-break: break-all;
}

.ui5-li__info {
  display: flex;
  align-items: center;
  margin-left: var(--sap-spacing-small);
  /* 确保插槽内容垂直居中 放置开关等组件时不会被压缩 */
  justify-content: flex-end;
  min-width: 44px;
}

.ui5-li__status {
  font-size: 14px;
  margin-right: 8px;
  color: var(--sap-text-secondary-color);
}