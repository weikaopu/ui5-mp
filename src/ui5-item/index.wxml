<view class="ui5-li" hover-class="ui5-li--active" bindtap="onTap">
  <!-- 左侧区域：支持 slot 或直接传入 icon 属性 -->
  <view class="ui5-li__icon-vip">
    <slot name="icon" wx:if="{{hasIconSlot}}"></slot>
    <ui5-icon wx:elif="{{icon}}" name="{{icon}}" size="20" color="{{iconColor || 'var(--sap-primary-color)'}}" />
  </view>

  <!-- 中间内容区 -->
  <view class="ui5-li__content">
    <view class="ui5-li__title">{{title}}</view>
    <!-- 应用动态行数 -->
    <view class="ui5-li__description" wx:if="{{description}}" style="-webkit-line-clamp: {{descriptionLines}};">
      {{description}}
    </view>
  </view>

  <!-- 右侧区域：支持插槽或默认状态文本，右侧信息/箭头 -->
  <view class="ui5-li__info">
    <block wx:if="{{hasActions}}">
      <slot name="actions"></slot>
    </block>
    <block wx:else>
      <text class="ui5-li__status" wx:if="{{status}}">{{status}}</text>
      <ui5-icon wx:if="{{type === 'Navigation'}}" name="arrow-right" size="14" color="#89919a" />
    </block>
  </view>
</view>