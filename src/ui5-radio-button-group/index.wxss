:host {
  display: block;
  margin-bottom: var(--sap-spacing-small, 16rpx);
}

.ui5-radio-button-group-root {
  display: flex;
  flex-direction: column;
}

.ui5-radio-group-label {
  font-size: var(--sap-font-size-small, 24rpx);
  color: var(--sap-text-secondary-color, #6a6d70);
  margin-bottom: var(--sap-spacing-tiny, 8rpx);
  font-weight: bold;
}

.ui5-radio-button-group--Column .ui5-radio-group-content {
  display: flex;
  flex-direction: column;
}

.ui5-radio-button-group--Row .ui5-radio-group-content {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

/* In row layout, add spacing between radio buttons */
.ui5-radio-button-group--Row ui5-radio-button {
  margin-right: var(--sap-spacing-medium, 32rpx);
}
