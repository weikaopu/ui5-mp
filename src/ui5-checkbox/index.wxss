:host {
  display: block;
}

.ui5-checkbox-root {
  display: flex;
  width: 100%;
  align-items: flex-start;
  padding: var(--sap-spacing-tiny, 8rpx) 0;
  cursor: pointer;
  user-select: none;
  outline: none;
}

/* A11y: Focus state to align with SAP Fiori focus ring */
.ui5-checkbox-root:active .ui5-checkbox-inner {
  outline: 2rpx solid var(--sap-content-focus-color, #0854a0);
  outline-offset: 4rpx;
}

.ui5-checkbox-inner {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  border: 2rpx solid var(--sap-field-border-color, #89919a);
  border-radius: 6rpx;
  background-color: var(--sap-content-color, #ffffff);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.1s ease-in;
}

.ui5-checkbox-active {
  background-color: var(--sap-primary-color, #0854a0);
  border-color: var(--sap-primary-color, #0854a0);
}

.ui5-checkbox-icon {
  display: flex;
  font-size: var(--sap-font-size-small, 24rpx);
  color: var(--sap-text-inverted-color, #ffffff);
}

.ui5-checkbox-label {
  flex: 1;
  min-width: 0;
  margin-left: var(--sap-spacing-small, 16rpx);
}

.ui5-checkbox-label-inner {
  display: flex;
  align-items: center;
  width: 100%;
  min-width: 0;
  overflow: hidden;
  color: red;
}

/* Value States - Horizon */
.ui5-checkbox-state-Error .ui5-checkbox-inner {
  border-color: var(--sap-error-color, #bb0000);
  border-width: 4rpx;
}

.ui5-checkbox-state-Warning .ui5-checkbox-inner {
  border-color: var(--sap-warning-color, #e9730c);
  border-width: 4rpx;
}

.ui5-checkbox-state-Success .ui5-checkbox-inner {
  border-color: var(--sap-success-color, #107e3e);
  border-width: 4rpx;
}

.ui5-checkbox-state-Information .ui5-checkbox-inner {
  border-color: var(--sap-information-color, #0a6ed1);
  border-width: 4rpx;
}

/* Disabled & Readonly */
.ui5-checkbox-disabled {
  opacity: 0.4;
}

.ui5-checkbox-readonly .ui5-checkbox-inner {
  background-color: var(--sap-background-color, #f7f7f7);
  border-color: var(--sap-field-border-color, #89919a);
}

.ui5-checkbox-readonly .ui5-checkbox-active {
  background-color: var(--sap-field-border-color, #89919a);
  border-color: var(--sap-field-border-color, #89919a);
}
