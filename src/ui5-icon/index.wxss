/* components/ui5-icon/index.wxss */
:host {
  display: inline-flex;
  /* 必须是 flex 或 inline-block，确保宽高生效 */
  align-items: center;
  justify-content: center;
  width: 24px;
  /* 默认外壳宽度 */
  height: 24px;
  /* 默认外壳高度 */
  vertical-align: middle;
}

.ui5-icon-canvas {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* --- 纯 CSS 实现 home (主页) 图标 --- */
.icon--home {
  width: 16px;
  height: 16px;
}

/* 屋顶部分：利用旋转的正方形或者边框画出三角形 */
.icon--home::before {
  content: "";
  position: absolute;
  top: 0;
  left: 50%;
  width: 10px;
  height: 10px;
  border-top: 2px solid currentColor;
  border-left: 2px solid currentColor;
  transform: translateX(-50%) rotate(45deg);
  border-top-left-radius: 1px;
}

/* 房屋主体部分 */
.icon--home::after {
  content: "";
  position: absolute;
  bottom: 1px;
  left: 50%;
  width: 12px;
  height: 9px;
  border-left: 2px solid currentColor;
  border-right: 2px solid currentColor;
  border-bottom: 2px solid currentColor;
  transform: translateX(-50%);
  background-color: transparent;
}

/* --- 纯 CSS 搜索图标 --- */
.icon--search::before {
  content: "";
  box-sizing: border-box;
  width: 14px;
  height: 14px;
  border: 2px solid currentColor;
  border-radius: 50%;
}

.icon--search::after {
  content: "";
  position: absolute;
  width: 2px;
  height: 6px;
  background: currentColor;
  bottom: 2px;
  right: 2px;
  transform: rotate(-45deg);
}

/* --- 纯 CSS 设置图标 --- */
.icon--settings::before {
  content: "";
  box-sizing: border-box;
  width: 14px;
  height: 14px;
  border: 4px double currentColor;
  /* 模拟齿轮感 */
  border-radius: 50%;
}

/* --- 纯 CSS 向右箭头 (Fiori 常用) --- */
.icon--arrow-right::before {
  content: "";
  width: 8px;
  height: 8px;
  border-top: 2px solid currentColor;
  border-right: 2px solid currentColor;
  transform: rotate(45deg);
}

/* --- 纯 CSS 向左返回箭头 (基于 Fiori 风格) --- */
.icon--arrow-left {
  display: inline-block;
  position: relative;
  width: 24px;
  /* 增加容器大小，方便点击 */
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon--arrow-left::before {
  content: "";
  width: 10px;
  /* 箭头折线长度 */
  height: 10px;
  /* 箭头折线长度 */
  border-top: 2px solid currentColor;
  border-right: 2px solid currentColor;
  /* 旋转 225 度使其指向左侧 */
  transform: rotate(-135deg);
  /* 微调位置，补偿旋转带来的视觉偏移 */
  margin-left: 4px;
}

/* 激活态缩放效果 (可选，提升交互感) */
.ui5-shellbar__back:active {
  opacity: 0.6;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 50%;
}


/* 纯 CSS 实现 decline (X) 图标 */
.icon--decline {
  width: 12px;
  height: 12px;
}

/* 关闭图标 (Decline) */
.icon--decline::before,
.icon--decline::after {
  content: "";
  position: absolute;
  width: 12px;
  height: 2px;
  background: currentColor;
  top: 50%;
  left: 50%;
}

.icon--decline::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.icon--decline::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

/* --- 纯 CSS 实现 accept (勾选) 图标 --- */
.icon--accept {
  width: 14px;
  height: 14px;
}

/* 勾选图标 (Accept) */
.icon--accept::before {
  content: "";
  position: absolute;
  width: 10px;
  height: 5px;
  border-left: 2px solid currentColor;
  border-bottom: 2px solid currentColor;
  transform: translate(-50%, -60%) rotate(-45deg);
  top: 50%;
  left: 50%;
}

.icon--contact::before {
  content: "";
  position: absolute;
  width: 8px;
  height: 8px;
  border: 2px solid currentColor;
  border-radius: 50%;
  top: 15%;
  left: 50%;
  transform: translateX(-50%);
}

.icon--contact::after {
  content: "";
  position: absolute;
  width: 14px;
  height: 8px;
  border: 2px solid currentColor;
  border-bottom: none;
  border-radius: 8px 8px 0 0;
  bottom: 15%;
  left: 50%;
  transform: translateX(-50%);
}


/* --- Information (圆圈 + i) --- */
.icon--message-information::before {
  content: "";
  position: absolute;
  width: 14px;
  height: 14px;
  border: 1.5px solid currentColor;
  border-radius: 50%;
}

.icon--message-information::after {
  content: "";
  position: absolute;
  width: 2px;
  height: 6px;
  background: currentColor;
  bottom: 3px;
  left: 7px;
  box-shadow: 0 -3px 0 0 currentColor;
  /* 顶部的点 */
}

/* --- Success (勾) --- */
.icon--message-success::before {
  content: "";
  position: absolute;
  width: 9px;
  height: 5px;
  border-left: 2px solid currentColor;
  border-bottom: 2px solid currentColor;
  transform: rotate(-45deg);
  top: 4px;
  left: 3px;
}

/* --- Warning (三角形 + !) --- */
.icon--message-warning::before {
  content: "";
  position: absolute;
  width: 0;
  height: 0;
  border-left: 8px solid transparent;
  border-right: 8px solid transparent;
  border-bottom: 14px solid currentColor;
  top: 0;
}

.icon--message-warning::after {
  content: "!";
  position: absolute;
  color: #fff;
  /* 警告三角形内的感叹号通常反色 */
  font-weight: bold;
  font-size: 10px;
  top: 2px;
  left: 6.5px;
}

/* --- Error (圆圈 + X) --- */
.icon--message-error::before,
.icon--message-error::after {
  content: "";
  position: absolute;
  width: 10px;
  height: 2px;
  background: currentColor;
  top: 7px;
  left: 3px;
}

.icon--message-error::before {
  transform: rotate(45deg);
}

.icon--message-error::after {
  transform: rotate(-45deg);
}

/* 外圈 */
.icon--message-error {
  border: 1.5px solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}