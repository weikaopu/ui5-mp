.ui5-button-wrapper {
  display: inline-block;
  position: relative;
  vertical-align: middle;
  overflow: visible;
}

.ui5-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 0 20rpx;
  height: 72rpx;
  min-width: 72rpx;
  border-radius: 8rpx;
  font-family: var(--sapFontFamily, "72", "72full", Arial, Helvetica, sans-serif);
  font-size: var(--sapFontSize, 28rpx);
  background-color: var(--sapButton_Background, #eff4f9);
  color: var(--sapButton_TextColor, #0064d2);
  border: 1rpx solid var(--sapButton_BorderColor, #0064d2);
  box-sizing: border-box;
  line-height: 1;
  overflow: visible;
  transition: opacity 0.1s;
}

.ui5-button::after {
  border: none;
}

.ui5-button-content {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.ui5-button-content--hidden {
  visibility: hidden;
}

.ui5-button-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.ui5-button-icon--start {
  margin-right: 12rpx;
}

.ui5-button-icon--end {
  margin-left: 12rpx;
}

.ui5-button--Emphasized {
  background-color: var(--sapButton_Emphasized_Background, #0064d2);
  color: #ffffff;
  border-color: var(--sapButton_Emphasized_BorderColor, #0064d2);
}

.ui5-button--Transparent {
  background-color: transparent;
  border-color: transparent;
}

.ui5-button--Positive {
  background-color: var(--sapButton_Accept_Background, #f6fdf9);
  color: #107e3e;
  border-color: #107e3e;
}

.ui5-button--Negative {
  background-color: var(--sapButton_Reject_Background, #fff4f4);
  color: #bb0000;
  border-color: #bb0000;
}

.ui5-button--Attention {
  background-color: var(--sapButton_Attention_Background, #fff8f0);
  color: #e9730c;
  border-color: #e9730c;
}

.ui5-button:active:not(.ui5-button--disabled) {
  opacity: 0.7;
  background-color: var(--sapButton_Active_Background, rgba(0, 100, 210, 0.1));
}

.ui5-button--disabled {
  opacity: var(--sapContent_DisabledOpacity, 0.4);
}

.ui5-button-busy-indicator {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.ui5-button-badge-slot {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  z-index: 2;
  pointer-events: none;
  transform: scale(0.85);
}

/* Tooltip 样式 */
.ui5-button-tooltip {
  position: fixed;
  transform: translateX(-50%);
  background-color: #32363a;
  color: #ffffff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  z-index: 1000;
  white-space: nowrap;
  pointer-events: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}
