.ui5-avatar {
  display: inline-block;
  position: relative;
  box-sizing: border-box;
  vertical-align: middle;
  background-color: var(--sapTile_Background, #ffffff);
  color: var(--sapContent_NonInteractiveIconColor, #0064d2);
  border: 1rpx solid var(--sapGroup_TitleBorderColor, #d9d9d9);
  /* 确保角标可以溢出显示在圆圈边缘 */
  overflow: visible;
}

.ui5-avatar-content {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.ui5-avatar--Circle,
.ui5-avatar--Circle .ui5-avatar-content {
  border-radius: 50%;
}

.ui5-avatar--Square,
.ui5-avatar--Square .ui5-avatar-content {
  border-radius: 8rpx;
}

/* Sizes Map */
.ui5-avatar--XS {
  width: 40rpx;
  height: 40rpx;
}

.ui5-avatar--S {
  width: 64rpx;
  height: 64rpx;
}

.ui5-avatar--M {
  width: 96rpx;
  height: 96rpx;
}

.ui5-avatar--L {
  width: 128rpx;
  height: 128rpx;
}

.ui5-avatar--XL {
  width: 192rpx;
  height: 192rpx;
}

.ui5-avatar--XS .ui5-avatar-initials {
  font-size: 16rpx;
}

.ui5-avatar--S .ui5-avatar-initials {
  font-size: 24rpx;
}

.ui5-avatar--M .ui5-avatar-initials {
  font-size: 36rpx;
}

.ui5-avatar--L .ui5-avatar-initials {
  font-size: 48rpx;
}

.ui5-avatar--XL .ui5-avatar-initials {
  font-size: 72rpx;
}

.ui5-avatar--XS .ui5-avatar-icon {
  font-size: 20rpx;
}

.ui5-avatar--S .ui5-avatar-icon {
  font-size: 32rpx;
}

.ui5-avatar--M .ui5-avatar-icon {
  font-size: 48rpx;
}

.ui5-avatar--L .ui5-avatar-icon {
  font-size: 64rpx;
}

.ui5-avatar--XL .ui5-avatar-icon {
  font-size: 96rpx;
}

.ui5-avatar-img {
  width: 100%;
  height: 100%;
}

.ui5-avatar-initials {
  font-family: var(--sapFontFamily, "72", "72full", Arial, Helvetica, sans-serif);
  font-weight: bold;
}

/* Badge Slot Positioning */
.ui5-avatar-badge-wrapper {
  position: absolute;
  bottom: 0;
  right: 0;
  z-index: 1;
  /* 将角标中心对准头像边缘 */
  transform: translate(25%, 25%);
}

.ui5-avatar--Circle .ui5-avatar-badge-wrapper {
  /* 对于圆形头像，角标中心需落在圆周边缘 */
  /* 计算公式: (1 - cos(45°)) / 2 ≈ 14.64% */
  bottom: 14.64%;
  right: 14.64%;
  /* 使用 50% 位移确保角标的中心点正好对准计算出的圆周位置 */
  transform: translate(50%, 50%);
}

/* 当 ui5-badge 作为角标使用时，强制变为圆形 */
.ui5-avatar-badge-wrapper ui5-badge {
  border-radius: 50% !important;
  padding: 0 !important;
  width: 40rpx !important;
  height: 40rpx !important;
  min-width: 40rpx !important;
  display: flex !important;
}

.ui5-avatar--interactive:active {
  background-color: var(--sapActiveColor, rgba(0, 100, 210, 0.1));
}

.ui5-avatar--disabled {
  opacity: var(--sapContent_DisabledOpacity, 0.4);
  pointer-events: none;
}

/* Tooltip */
.ui5-avatar-tooltip {
  position: fixed;
  transform: translateX(-50%);
  background-color: #32363a;
  color: #ffffff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  z-index: 1000;
}
