/* 引入你的全局样式变量 */
.ui5-slider-container {
  padding: 20px 12px;
  /* 留出 Tooltip 和 Handle 的溢出空间 */
  width: 100%;
  box-sizing: border-box;
}

.ui5-slider-inner {
  position: relative;
  height: 48px;
  /* 增大触摸热区 */
  display: flex;
  align-items: center;
  cursor: pointer;
}

/* 轨道基底 */
.ui5-slider-rail {
  position: absolute;
  width: 100%;
  height: 4px;
  background-color: #d8d8d8;
  /* Horizon track background */
  border-radius: 2px;
}

/* 进度条 */
.ui5-slider-progress {
  position: absolute;
  height: 4px;
  background-color: var(--sap-primary-color);
  border-radius: 2px;
}

/* 滑块 Handle */
.ui5-slider-handle {
  position: absolute;
  width: 22px;
  height: 22px;
  background-color: var(--sap-content-color);
  border: 1px solid var(--sap-field-border-color);
  border-radius: 50%;
  transform: translate(-50%, 0);
  /* 居中对齐 */
  box-shadow: var(--sap-shadow-level-1);
  transition: transform 0.1s ease-out, box-shadow 0.2s;
  z-index: 2;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 激活状态（按下时） */
.ui5-slider-handle-active {
  box-shadow: 0 0 0 6px rgba(8, 84, 160, 0.15);
  /* SAP Horizon Focus Ring */
  border-color: var(--sap-primary-color);
  transform: translate(-50%, 0) scale(1.1);
}

/* 数值提示 Tooltip */
.ui5-slider-tooltip {
  position: absolute;
  top: -35px;
  background-color: var(--sap-shell-color);
  color: var(--sap-text-inverted-color);
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
  white-space: nowrap;
}

/* 轨道中间的点 (Tickmarks) 可根据需要添加，此处保持简洁 */
/* Handle 内部的小圆点 */
.ui5-slider-handle-dot {
  width: 4px;
  height: 4px;
  background-color: var(--sap-primary-color);
  border-radius: 50%;
}

/* 禁用状态整体透明度 */
.ui5-slider-disabled {
  opacity: 0.5;
  pointer-events: none;
  /* 确保点击无效 */
}

/* 禁用状态下的轨道和进度条背景色 */
.ui5-slider-disabled .ui5-slider-progress {
  background-color: var(--sap-neutral-color);
  /* 变灰 */
}

.ui5-slider-disabled .ui5-slider-handle {
  border-color: var(--sap-neutral-color);
  box-shadow: none;
  /* 移除阴影 */
}

.ui5-slider-disabled .ui5-slider-handle-dot {
  background-color: var(--sap-neutral-color);
  /* 小圆点变灰 */
}

/* 保持之前的 Handle 基础样式，确保居中 */
.ui5-slider-handle {
  position: absolute;
  width: 22px;
  height: 22px;
  background-color: var(--sap-content-color);
  border: 1px solid var(--sap-field-border-color);
  border-radius: 50%;
  transform: translate(-50%, 0);
  box-shadow: var(--sap-shadow-level-1);
  z-index: 2;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: transform 0.1s ease-out, box-shadow 0.2s;
}

/* 新增外层包装，确保 Label 和轨道水平对齐 */
.ui5-slider-wrapper {
  display: flex;
  align-items: center;
  gap: 12px;
  /* 轨道与文字的间距 */
  width: 100%;
}

/* Label 样式：符合 SAP 辅助文字风格 */
.ui5-slider-label {
  font-size: var(--sap-font-size-small);
  color: var(--sap-text-secondary-color);
  min-width: 24px;
  /* 防止数值长度变化导致轨道抖动 */
  text-align: center;
  font-family: inherit;
}

/* 确保轨道占据剩余所有空间 */
.ui5-slider-inner {
  position: relative;
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
}

/* 保持之前的进度条、滑块、Tooltip 等样式不变... */
.ui5-slider-rail {
  position: absolute;
  width: 100%;
  height: 4px;
  background-color: #d8d8d8;
  border-radius: 2px;
}


.ui5-slider-tickmarks {
  position: absolute;
  width: 100%;
  height: 4px;
  /* 与轨道高度一致 */
  z-index: 1;
}

.ui5-slider-tick {
  position: absolute;
  top: 50%;
  width: 2px;
  height: 2px;
  background-color: #a9adb2;
  /* 默认刻度色 */
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

/* 已激活进度的刻度点颜色（可选，Horizon 规范中有时会略微加深或变色） */
.ui5-slider-tick-active {
  background-color: rgba(255, 255, 255, 0.5);
}

/* 进度条需要比刻度点层级高，或者刻度点放在进度条之上 */
.ui5-slider-progress {
  z-index: 1;
}

.ui5-slider-handle {
  z-index: 3;
}