/**
 * 全局样式库应当严格对齐 SAP Fiori 3 (Quartz Light) 或最新的 Horizon 主题色调。
 * ui5-mp: SAP Fiori Styles for Mini Program
 * Core Design Tokens & Global Styles
 */

page {
  /* --- Color Palette (SAP Quartz Light / Horizon) --- */
  --sap-primary-color: #0854a0;
  --sap-shell-color: #354a5f;
  --sap-background-color: #f7f7f7;
  --sap-content-color: #ffffff;

  /* Semantic Colors */
  --sap-success-color: #107e3e;
  --sap-warning-color: #e9730c;
  --sap-error-color: #bb0000;
  --sap-information-color: #0a6ed1;
  --sap-neutral-color: #6a6d70;

  /* Interaction Colors */
  --sap-content-focus-color: #0854a0;
  --sap-active-color: #0854a0;
  --sap-selected-color: #0854a0;

  /* Focus Ring Settings */
  --sap-content-focus-width: 2rpx;
  --sap-content-focus-style: solid;

  /* Text Colors */
  --sap-text-color: #32363a;
  --sap-text-secondary-color: #6a6d70;
  --sap-text-inverted-color: #ffffff;

  /* Border & Field Colors */
  --sap-field-border-color: #89919a;
  --sap-field-background-color: #ffffff;
  --sap-group-title-color: #6a6d70;

  /* Value State Colors (for text and icons) */
  --sap-value-state-error-color: #bb0000;
  --sap-value-state-warning-color: #e9730c;
  --sap-value-state-success-color: #107e3e;
  --sap-value-state-info-color: #0a6ed1;

  /* --- Layout & Spacing --- */
  /* 4px */
  --sap-spacing-tiny: 8rpx;
  /* 8px */
  --sap-spacing-small: 16rpx;
  /* 16px */
  --sap-spacing-medium: 32rpx;
  /* 32px */
  --sap-spacing-large: 64rpx;

  /* --- Borders & Shadows --- */
  --sap-border-radius: 16rpx;
  /* Horizon style uses larger radius, Quartz uses 4px */
  --sap-shadow-level-1: 0 0 4rpx 0 rgba(0, 0, 0, 0.1), 0 8rpx 16rpx 0 rgba(0, 0, 0, 0.1);
  --sap-shadow-level-2: 0 0 4rpx 0 rgba(0, 0, 0, 0.1), 0 16rpx 32rpx 0 rgba(0, 0, 0, 0.2);

  /* --- Typography --- */
  --sap-font-size: 28rpx;
  --sap-font-size-small: 24rpx;
  --sap-font-size-large: 32rpx;
  --sap-font-size-header: 40rpx;
  --sap-font-weight-bold: 700;

  /* Base Styles */
  background-color: var(--sap-background-color);
  color: var(--sap-text-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  font-size: var(--sap-font-size);
  line-height: 1.4;
  -webkit-font-smoothing: antialiased;

  /* SAP VizFrame Standard Palette */
  --sap-viz-color-1: #5899da;
  /* Blue */
  --sap-viz-color-2: #e8743b;
  /* Orange */
  --sap-viz-color-3: #19a979;
  /* Green */
  --sap-viz-color-4: #ed4a7b;
  /* Red */
  --sap-viz-color-5: #945ecf;
  /* Purple */
  --sap-viz-grid-line: #f0f0f0;
  --sap-viz-axis-label: #6a6d70;
}

/* 基础辅助类：快速应用 SAP 边距 */
.fd-margin-md {
  margin: var(--sap-spacing-medium);
}

.fd-margin-top-md {
  margin-top: var(--sap-spacing-medium);
}

.fd-margin-bottom-md {
  margin-bottom: var(--sap-spacing-medium);
}

.fd-margin-top-sm {
  margin-top: var(--sap-spacing-small);
}

.fd-margin-bottom-sm {
  margin-bottom: var(--sap-spacing-small);
}

.fd-padding-md {
  padding: var(--sap-spacing-medium);
}

/* 几何对齐辅助类：消除基线干扰，实现完美的中心对齐 */
.ui5-mp-flex-center {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* Flex 方向辅助类 */
.ui5-mp-flex-column {
  display: flex !important;
  flex-direction: column !important;
}

.ui5-mp-flex-row {
  display: flex !important;
  flex-direction: row !important;
  align-items: center;
}

.ui5-mp-flex-wrap {
  flex-wrap: wrap !important;
}

/* 填充剩余空间 */
.ui5-mp-flex-fill {
  flex: 1 !important;
  min-width: 0;
}

/* 逻辑方向边距：对齐 SAP Fiori 规范 (Begin = Left in LTR) */
.fd-margin-begin-md {
  margin-left: var(--sap-spacing-medium) !important;
}

.fd-margin-begin-sm {
  margin-left: var(--sap-spacing-small) !important;
}

/* 容器类：模拟 Fiori Page 布局 */
.ui5-page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 文本类：次要辅助文字 */
.ui5-text-secondary {
  color: var(--sap-text-secondary-color);
  font-size: var(--sap-font-size-small);
}

/* 状态类：成功/错误等文本颜色 */
.ui5-text-success {
  color: var(--sap-success-color);
}

.ui5-text-error {
  color: var(--sap-error-color);
}

/**
 * 针对原生组件的重置 (Reset)
 * 小程序的 button/input 等自带样式较重，需要在这里统一处理基础外观
 */
button::after {
  border: none;
}

input {
  font-family: inherit;
}
