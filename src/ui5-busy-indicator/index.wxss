:host {
  /* 当全局变量 --ui5-global-busy 为 1 时，强制隐藏局部组件 */
  display: block;
}

.ui5-busy-indicator-root {
  position: relative;
}

.ui5-busy-container {
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ui5-busy-container.is-active {
  display: flex;
}

/* 利用变量控制局部组件的可见性 */
.ui5-busy-container:not(.is-full-screen) {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  /* 如果全局 busy 开启，则局部 busy 的透明度降为 0 且不可交互 */
  opacity: calc(1 - var(--ui5-global-busy, 0));
  pointer-events: calc(1 - var(--ui5-global-busy, 0));
  transition: opacity 0.2s;
}

/* 全屏模式必须独立，不被上面的变量影响可见性 */
.ui5-busy-container.is-full-screen {
  position: fixed !important;
  top: 0;
  left: 0;
  bottom: 0;
  right: 0;
  z-index: 90 !important;
  /* 确保低于 Shellbar (100) 和 Footer 的层级 */
  background-color: rgba(255, 255, 255, 0.8);
  display: none;
  /* 默认隐藏 */
}

/* 只有在 active 时才显示 */
.ui5-busy-container.is-active.is-full-screen {
  display: flex !important;
  opacity: 1 !important;
  /* 强制覆盖局部抑制变量 */
}

.ui5-busy-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  /* 圆点间距 */
}

.ui5-busy-dot {
  width: 16rpx;
  height: 16rpx;
  background-color: var(--sap-primary-color);
  border-radius: 50%;
  animation: ui5-busy-bounce 1.2s infinite ease-in-out;
}

/* 三个点的动画延迟 */
.ui5-busy-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.ui5-busy-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes ui5-busy-bounce {

  0%,
  80%,
  100% {
    transform: scale(0.4);
    opacity: 0.3;
  }

  40% {
    transform: scale(1.0);
    opacity: 1;
  }
}

/* --- 尺寸 --- */
.ui5-busy--S .ui5-busy-dot {
  width: 8rpx;
  height: 8rpx;
}

.ui5-busy--L .ui5-busy-dot {
  width: 24rpx;
  height: 24rpx;
  gap: 20rpx;
}

.ui5-busy-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--sap-primary-color);
}

.ui5-busy-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(255, 255, 255, 0.8);
  /* Fiori 风格的白色半透明遮罩 */
  backdrop-filter: blur(2px);
  /* 现代 Fiori Horizon 风格的毛玻璃效果 */
}

.ui5-busy-content {
  position: relative;
  z-index: 2001;
  display: flex;
  flex-direction: column;
  align-items: center;
}
