.ui5-table-row {
  display: flex;
  flex-direction: column;
  padding: 12px 16px;
  background: var(--sap-content-color);
  border-bottom: 1px solid var(--sap-border-color);
}

.ui5-table-row__main {
  display: flex;
  width: 100%;
  align-items: flex-start;
}

.ui5-table-row__title {
  font-weight: bold;
  font-size: 15px;
}

/* Popin 列表样式 */
.ui5-table-row__popin {
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px dashed var(--sap-border-color); /* 内部微弱分割 */
}

.ui5-table-row__popin-item {
  display: flex;
  flex-direction: row; /* 从 column 改为 row */
  align-items: flex-start;
  margin-bottom: 4px;
}

.ui5-table-row__popin-label {
  width: 35%; /* 固定 Label 宽度 */
  font-size: 12px;
  color: var(--sap-text-secondary-color);
  padding-right: 8px;
  flex-shrink: 0;
}

.ui5-table-row__popin-value {
  flex: 1;
  font-size: 13px;
  color: var(--sap-text-color);
  word-break: break-all;
}
