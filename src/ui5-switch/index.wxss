:host {
  display: inline-block;
  vertical-align: middle;
}

.ui5-switch {
  width: 52px;
  /* 标准宽度 */
  height: 30px;
  box-sizing: border-box;
  position: relative;
  cursor: pointer;
}

.ui5-switch__track {
  width: 100%;
  height: 100%;
  background-color: var(--sap-field-background-color);
  border: 1px solid var(--sap-field-border-color);
  border-radius: 15px;
  /* 完全圆角 */
  position: relative;
  transition: background-color 0.2s, border-color 0.2s;
  overflow: hidden;
}

.ui5-switch__handle {
  position: absolute;
  top: 3px;
  left: 3px;
  width: 22px;
  height: 22px;
  background-color: #fff;
  border-radius: 50%;
  box-shadow: var(--sap-shadow-level-1);
  transition: transform 0.2s cubic-bezier(0.25, 0.1, 0.25, 1);
  z-index: 2;
}

/* 文本/图标样式 */
.ui5-switch__text {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  font-size: 10px;
  font-weight: bold;
  transition: opacity 0.2s;
}

.ui5-switch__text--on {
  left: 8px;
  color: #fff;
  opacity: 0;
}

.ui5-switch__text--off {
  right: 8px;
  color: var(--sap-text-secondary-color);
  opacity: 1;
}

/* --- 选中状态 (Checked) --- */
.is-checked .ui5-switch__track {
  background-color: var(--sap-primary-color);
  border-color: var(--sap-primary-color);
}

.is-checked .ui5-switch__handle {
  transform: translateX(22px);
  /* 移动到右侧 */
}

.is-checked .ui5-switch__text--on {
  opacity: 1;
}

.is-checked .ui5-switch__text--off {
  opacity: 0;
}

/* 禁用态 */
.is-disabled {
  opacity: 0.4;
}