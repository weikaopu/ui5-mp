/* 复用基础容器样式 */
.ui5-viz-container {
  background: var(--sap-content-color);
  padding: 16px;
  border-radius: var(--sap-border-radius);
}

.ui5-viz-chart-wrapper {
  position: relative;
  width: 100%;
  height: 240px;
  /* 环形图通常不需要太高 */
  display: flex;
  justify-content: center;
  align-items: center;
}

.ui5-viz-canvas {
  width: 100%;
  height: 100%;
}

/* Tooltip 样式优化 */
.ui5-viz-tooltip {
  position: absolute;
  background: rgba(53, 74, 95, 0.95);
  color: #fff;
  padding: 8px 12px;
  border-radius: 4px;
  font-size: 11px;
  pointer-events: none;
  z-index: 10;
  transform: translate(-50%, -100%);
  box-shadow: var(--sap-shadow-level-2);
}

.ui5-viz-tooltip-item {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}

.ui5-viz-tooltip-marker {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-right: 6px;
}

.ui5-viz-tooltip-value {
  font-weight: bold;
  font-size: 13px;
  padding-left: 14px;
}

/* 图例样式复用之前定义的 */
.ui5-viz-legend {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12px;
  margin-top: 16px;
}

.ui5-viz-legend-item {
  display: flex;
  align-items: center;
}

.ui5-viz-legend-icon {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-right: 6px;
}

.ui5-viz-legend-text {
  font-size: 12px;
  color: var(--sap-text-secondary-color);
}