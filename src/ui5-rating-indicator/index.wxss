:host {
  display: inline-block;
  vertical-align: middle;
}

.ui5-rating {
  display: flex;
  flex-direction: column;
}

.ui5-rating__label {
  font-size: 12px;
  color: var(--sap-text-secondary-color);
  margin-bottom: 4px;
}

.ui5-rating__stars {
  display: flex;
  gap: 4px;
}

.ui5-rating__star-container {
  padding: 4px;
  /* 增大点击热区 */
}

/* 状态控制 */
.is-disabled {
  opacity: 0.4;
  pointer-events: none;
}

.is-readonly {
  pointer-events: none;
}
