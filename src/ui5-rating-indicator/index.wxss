:host {
  display: inline-block;
  vertical-align: middle;
}

.ui5-rating {
  display: flex;
  flex-direction: column;
}

.ui5-rating__label {
  font-size: 12px;
  color: var(--sap-text-secondary-color);
  margin-bottom: 4px;
}

.ui5-rating__stars {
  display: flex;
  gap: 4px;
}

.ui5-rating__star-container {
  padding: 4px;
  /* 增大点击热区 */
}

/* --- 纯 CSS 五角星 --- */
.ui5-star {
  position: relative;
  display: block;
  width: 0px;
  height: 0px;
  border-right: 10px solid transparent;
  border-bottom: 7px solid #d3d3d3;
  /* 未选中颜色 */
  border-left: 10px solid transparent;
  transform: rotate(35deg);
  transition: border-bottom-color 0.2s;
}

.ui5-star::before {
  content: "";
  position: absolute;
  top: -4px;
  left: -6px;
  width: 0px;
  height: 0px;
  border-right: 3px solid transparent;
  border-bottom: 8px solid #d3d3d3;
  border-left: 3px solid transparent;
  transform: rotate(-35deg);
  transition: border-bottom-color 0.2s;
}

.ui5-star::after {
  content: "";
  position: absolute;
  top: 0px;
  left: -10px;
  width: 0px;
  height: 0px;
  border-right: 10px solid transparent;
  border-bottom: 7px solid #d3d3d3;
  border-left: 10px solid transparent;
  transform: rotate(-70deg);
  transition: border-bottom-color 0.2s;
}

/* --- 选中状态：SAP Horizon 蓝色或 Fiori 经典金色 --- */
/* 这里我们统一使用 Fiori 经典的金色 #e38b16 以增强对比度 */
.ui5-star.is-selected,
.ui5-star.is-selected::before,
.ui5-star.is-selected::after {
  border-bottom-color: #e38b16;
}

/* 状态控制 */
.is-disabled {
  opacity: 0.4;
  pointer-events: none;
}

.is-readonly {
  pointer-events: none;
}