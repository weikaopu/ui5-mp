:host {
  display: block;
  margin: var(--sap-spacing-medium);
}

.ui5-card {
  background-color: var(--sap-content-color);
  border: 1px solid var(--sap-border-color);
  border-radius: var(--sap-border-radius);
  box-shadow: var(--sap-shadow-level-1);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.ui5-card--interactive:active {
  background-color: #f7f7f7;
  transform: scale(0.995);
}

/* 头部样式 */
.ui5-card__header {
  padding: 16px;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  border-bottom: 1px solid var(--sap-border-color);
}

.ui5-card__header-main {
  display: flex;
  flex: 1;
}

.ui5-card__header-icon {
  margin-right: 12px;
  padding-top: 2px;
}

.ui5-card__title {
  font-size: 18px;
  font-weight: 600;
  color: var(--sap-text-color);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ui5-card__subtitle {
  font-size: 12px;
  color: var(--sap-text-secondary-color);
  margin-top: 4px;
}

.ui5-card__status {
  font-size: 14px;
  color: var(--sap-primary-color);
  font-weight: 500;
  margin-left: 12px;
}

/* 内容区样式 */
.ui5-card__content {
  padding: 0;
  /* 默认 0，让内部的 list 可以填满卡片 */
}

.ui5-card__scroll {
  overflow-x: auto;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
  width: 100%;
}

.ui5-card__scroll-inner {
  min-width: 100%;
}