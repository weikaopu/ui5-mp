.ui5-viz-container {
  background: var(--sap-content-color);
  padding: 16px;
  border-radius: var(--sap-border-radius);
}

.ui5-viz-title {
  font-size: var(--sap-font-size-large);
  font-weight: bold;
  color: var(--sap-text-color);
  margin-bottom: 16px;
  display: block;
}

.ui5-viz-chart-wrapper {
  position: relative;
  width: 100%;
  height: 280px;
  /* 增加高度以容纳坐标轴数字 */
}

.ui5-viz-canvas {
  width: 100%;
  height: 100%;
}

.ui5-viz-tooltip {
  position: absolute;
  background: rgba(53, 74, 95, 0.95);
  /* --sap-shell-color */
  color: #ffffff;
  padding: 6px 10px;
  border-radius: 4px;
  font-size: 11px;
  pointer-events: none;
  z-index: 10;
  transform: translate(-50%, -110%);
  box-shadow: var(--sap-shadow-level-2);
  transition: opacity 0.2s;
}

.ui5-viz-tooltip-label {
  opacity: 0.7;
  margin-bottom: 2px;
}

.ui5-viz-tooltip-value {
  font-weight: bold;
}