/* 复用柱状图基础样式 */
.ui5-viz-container {
  background: var(--sap-content-color);
  padding: 16px;
  border-radius: var(--sap-border-radius);
}

.ui5-viz-title {
  font-size: var(--sap-font-size-large);
  font-weight: bold;
  color: var(--sap-text-color);
  margin-bottom: 16px;
  display: block;
}

.ui5-viz-chart-wrapper {
  position: relative;
  width: 100%;
  height: 280px;
}

.ui5-viz-canvas {
  width: 100%;
  height: 100%;
}

.ui5-viz-tooltip {
  position: absolute;
  background: rgba(53, 74, 95, 0.95);
  color: #fff;
  padding: 8px 12px;
  border-radius: 4px;
  font-size: 11px;
  pointer-events: none;
  transform: translate(-50%, -110%);
  box-shadow: var(--sap-shadow-level-2);
}

.ui5-viz-tooltip-header {
  font-weight: bold;
  margin-bottom: 6px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  padding-bottom: 4px;
}

.ui5-viz-tooltip-item {
  display: flex;
  align-items: center;
  margin-bottom: 3px;
}

.ui5-viz-tooltip-marker {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-right: 6px;
}

.ui5-viz-tooltip-name {
  flex: 1;
  margin-right: 12px;
  opacity: 0.8;
}


.ui5-viz-legend {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16px;
  margin-top: 16px;
  padding: 0 8px;
}

.ui5-viz-legend-item {
  display: flex;
  align-items: center;
}

.ui5-viz-legend-icon {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-right: 6px;
}

.ui5-viz-legend-text {
  font-size: var(--sap-font-size-small);
  color: var(--sap-text-secondary-color);
}

/* 针对 Line Chart，图例图标可以改为细长条形状（可选） */
.ui5-viz-legend-icon {
  width: 12px;
  height: 3px;
  border-radius: 2px;
}