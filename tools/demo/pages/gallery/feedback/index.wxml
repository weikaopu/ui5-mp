<ui5-page busy="{{isGlobalLoading}}" busy-text="System is updating...">
  <ui5-shellbar slot="header" title="Feedback Components" />

  <view class="fd-padding-md">

    <!-- MessageStrip: 页面内嵌通知 -->
    <ui5-card title="Message Strip">
      <view class="fd-padding-md">
        <ui5-message-strip type="information" hideCloseButton="true">
          Information: New updates are available for this product.
        </ui5-message-strip>

        <ui5-message-strip type="success" style="margin-top: 10px;">
          Success: Your profile has been updated.
        </ui5-message-strip>

        <ui5-message-strip type="warning" style="margin-top: 10px;">
          Warning: Low disk space detected on the server.
        </ui5-message-strip>

        <ui5-message-strip type="error" style="margin-top: 10px;" bind:close="onStripClose">
          Error: Failed to connect to the database.
        </ui5-message-strip>
      </view>
    </ui5-card>

    <!-- Busy Indicator: 局部与全屏加载 -->
    <ui5-card title="Busy Indicator, Loading States">
      <view class="fd-padding-md" style="text-align: center;">
        <view class="ui5-text-secondary">Local Loading (Small):</view>
        <ui5-busy-indicator active size="S" />

        <view class="ui5-text-secondary" style="margin-top: 20px;">Global Loading Trigger:</view>
        <ui5-button bind:click="triggerGlobalLoading" style="margin-top: 10px;">
          Show Full Screen Busy
        </ui5-button>
      </view>
    </ui5-card>

    <!-- Toast: 轻量化弹出提示 -->
    <ui5-card title="Toast Message">
      <view class="fd-padding-md">
        <ui5-button type="transparent" bind:click="showToast">
          Show Toast Notification
        </ui5-button>
      </view>
    </ui5-card>

  </view>

  <!-- 全局组件定义 -->
  <ui5-toast id="demoToast"></ui5-toast>
</ui5-page>