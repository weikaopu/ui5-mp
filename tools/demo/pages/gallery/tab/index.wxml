<ui5-page>
  <ui5-shellbar slot="header" title="Tab Container" />

  <view class="fd-padding-md">

    <!-- 场景 1: 标准图标页签 (IconTabBar) -->
    <view class="gallery-section-title">Icon Tab Bar</view>
    <ui5-card title="Product Details">
      <ui5-tab-container currentKey="info" bind:change="onTabChange">
        <ui5-tab key="info" text="Info" icon="sap-icon://home">
          <view class="fd-padding-md">
            <view class="ui5-text-secondary">General Information</view>
            <view style="margin-top: 10px;">This project is built using ui5-mp, an enterprise-grade UI library for
              WeChat Mini Programs.</view>
          </view>
        </ui5-tab>

        <ui5-tab key="attachments" text="Files" icon="sap-icon://settings">
          <view class="fd-padding-md">
            <ui5-list no-border>
              <ui5-item title="specification.pdf" description="2.4 MB" icon="sap-icon://search" />
              <ui5-item title="design_draft.png" description="1.1 MB" icon="sap-icon://search" />
            </ui5-list>
          </view>
        </ui5-tab>

        <ui5-tab key="notes" text="Notes" icon="sap-icon://contacts">
          <view class="fd-padding-md">
            <ui5-textarea placeholder="Add a private note..." rows="4" growing />
          </view>
        </ui5-tab>
      </ui5-tab-container>
    </ui5-card>

    <!-- 场景 2: 纯文本页签 (Text Only) -->
    <view class="gallery-section-title">Text Only Tabs</view>
    <ui5-tab-container currentKey="tab1">
      <ui5-tab key="tab1" text="All Items">
        <view class="fd-padding-md">Showing all records from the database.</view>
      </ui5-tab>
      <ui5-tab key="tab2" text="Pending">
        <view class="fd-padding-md">No pending tasks at the moment.</view>
      </ui5-tab>
      <ui5-tab key="tab3" text="Completed">
        <view class="fd-padding-md">5 tasks completed today.</view>
      </ui5-tab>
    </ui5-tab-container>

  </view>
</ui5-page>
