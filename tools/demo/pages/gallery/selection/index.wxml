<ui5-page>
  <ui5-shellbar slot="header" title="Selection Components" />

  <view class="fd-padding-md">

    <!-- Select: 底部抽屉选择 -->
    <ui5-card title="Select">
      <view class="fd-padding-md">
        <ui5-select label="Country/Region" options="{{countries}}" value="{{selectedCountry}}"
          bind:change="onSelectChange" />
        <ui5-select label="Shipping Method (Error)" options="{{shipping}}" valueState="Error"
          valueStateText="This method is currently unavailable" style="margin-top: 16px;" />
      </view>
    </ui5-card>

  </view>
</ui5-page>
