/* tools/demo/pages/gallery/switch/index.wxss */
/* Minimal custom styles, leveraging Fundamental Styles for layout */
.fd-padding-md {
  padding: 1rem;
}

.fd-d-flex {
  display: flex;
}

.fd-align-items-center {
  align-items: center;
}

.fd-justify-content-between {
  justify-content: space-between;
}


.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  min-height: 80rpx;
  border-bottom: 1rpx solid #eeeeee;
}
